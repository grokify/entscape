{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grokify/entscape/schema/entscape.schema.json",
  "properties": {
    "version": {
      "type": "string"
    },
    "package": {
      "properties": {
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "docs": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name"
      ]
    },
    "entities": {
      "items": {
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "fields": {
            "items": {
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "attrs": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "description": {
                  "type": "string"
                },
                "default": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "required": [
                "name",
                "type"
              ]
            },
            "type": "array"
          },
          "edges": {
            "items": {
              "properties": {
                "name": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "relation": {
                  "type": "string"
                },
                "inverse": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                },
                "unique": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "required": [
                "name",
                "target",
                "relation"
              ]
            },
            "type": "array"
          },
          "indexes": {
            "items": {
              "properties": {
                "fields": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "unique": {
                  "type": "boolean"
                },
                "edges": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "required": [
                "fields"
              ]
            },
            "type": "array"
          },
          "mixins": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name"
        ]
      },
      "type": "array"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "version",
    "entities"
  ],
  "title": "Entscape Schema",
  "description": "JSON schema for entscape visualization data"
}